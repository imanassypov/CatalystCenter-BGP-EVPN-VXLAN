# Copy to .env in this directory (gitignored):
#   cp .env.example .env
#
# Loaded automatically on `cd` via direnv (.envrc). Ansible, verify scripts, and
# the MCP SSH server all read this file. Use quotes for values with spaces or #.

# IOS-XE / NX-OS fabric devices (net-admin)
IOSXE_PASS=

# dCloud script-server jump host (198.18.134.28) — password only (no SSH key)
SCRIPT_SERVER_SSH_PASS=

# Cloud Splunk / OTel EC2 (18.224.25.161) — reached via script-server jump host
SPLUNK_SSH_KEY_PATH=utils/mcp-ssh-server/splunk-creds/ec2user-splunk.pem
SPLUNK_ADMIN_USER=
SPLUNK_ADMIN_PASS=

# CML dynamic inventory (fabric lab API — not the script-server jump host)
CML_HOST=198.18.128.11
CML_USERNAME=admin
CML_PASSWORD=
CML_LAB=BGP EVPN Campus

# MCP SSH inventory (paths relative to CICD Pipeline/)
MCP_SSH_INVENTORY=utils/mcp-ssh-server/inventory/cml.yml
MCP_SSH_STATIC_HOSTS=utils/mcp-ssh-server/inventory/static_hosts.yml
