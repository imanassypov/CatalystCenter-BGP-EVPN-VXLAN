---
# =============================================================================
# SECRETS TEMPLATE — copy to vault.yml and encrypt:
#
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# connection.yml maps these into Ansible SSH/become variables:
# NOTE: password SSH auth requires 'sshpass' on the control node
#       (brew install sshpass / apt install sshpass). If you use SSH keys
#       instead, drop vault_image_server_password and remove ansible_ssh_pass
#       from vars.yml.
# =============================================================================

vault_image_server_user: "ubuntu"
vault_image_server_password: "CHANGE_ME"
vault_image_server_become_password: "CHANGE_ME"
