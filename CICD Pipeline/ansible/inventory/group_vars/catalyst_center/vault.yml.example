---
# vault.yml.example — copy to vault.yml and encrypt:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml --vault-password-file ../.vault_pass
#
# Catalyst Center API credentials (used by all pipeline stages).
catc_username: admin
catc_password: your_catc_password_here

# Device SSH credentials (stage 11 backup)
vault_device_username: admin
vault_device_password: your_device_password_here
vault_device_enable_password: your_enable_password_here

# GitHub token (stage 7 template sync) — optional if using SSH deploy keys
# git_token: your_github_token_here
