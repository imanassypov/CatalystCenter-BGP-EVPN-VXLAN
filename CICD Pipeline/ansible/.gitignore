# Ansible runtime artifacts
.ansible/
logs/
config-backups/*/
!config-backups/.gitkeep
*.log

# Encrypted vault files and symlinks (use vault.yml.example; never commit secrets)
inventory/group_vars/**/vault.yml
!inventory/group_vars/**/vault.yml.example
inventory/group_vars/**/vault.yml.placeholder.bak
inventory/group_vars/image_servers/vars.yml
inventory/group_vars/yangsuite_servers/vars.yml
