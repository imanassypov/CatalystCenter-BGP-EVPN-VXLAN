# Managed by Ansible (CICD Pipeline/ansible/roles/http_image_server) — do not edit by hand.
# Serves Cisco SWIM .bin images to Catalyst Center over anonymous HTTP.
server {
    listen 80 default_server;
    server_name {{ image_server_ip }};
    root {{ image_web_root }};

    location /{{ image_url_subdir }}/ {
        autoindex on;
        sendfile on;
        default_type application/octet-stream;
    }
}
