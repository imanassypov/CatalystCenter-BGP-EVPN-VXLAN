# Copy to .env in this directory (gitignored):
#   cp .env.example .env
#
# The MCP server loads this file on startup. Values here are defaults;
# variables already set in the process environment (e.g. .vscode/mcp.json)
# take precedence.

# IOS-XE / NX-OS fabric devices (net-admin)
IOSXE_PASS=

# dCloud script-server jump host (198.18.134.28) — key and/or password
SSH_BASTION_KEY=
SCRIPT_SERVER_SSH_PASS=

# Cloud Splunk / OTel EC2 (18.224.25.161) — reached via script-server jump host
# SSH: ec2-user + PEM (EC2 publickey only). Default key:
#   splunk-creds/ec2user-splunk.pem  (relative to this directory)
SPLUNK_SSH_KEY_PATH=splunk-creds/ec2user-splunk.pem
# Splunk admin / application password (Search & Reporting, REST, splunk search -auth)
SPLUNK_ADMIN_USER=
SPLUNK_ADMIN_PASS=
