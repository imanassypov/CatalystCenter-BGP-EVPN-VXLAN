{## CATC: productFamily=Switches and Hubs, softwareType=IOS-XE, productSeries=Cisco Catalyst 9000 Series Virtual Switches ##}
{# FABRIC-CLIENT-PORTS.j2 - Client-Facing Access Port Configuration #}
{# Generates switchport access VLAN configs on leaf switches for client-facing interfaces #}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-ROLES.j2" %}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-CLIENT-PORTS.j2" %}

{# === Dereference device context === #}
{% set DEVICE_HOSTNAME = __device.hostname | default('', true) %}

{# === Client-Facing Port Configuration (Leaves only) === #}
{# Skip for Spine and Border nodes #}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE'] %}
{# Skip: BORDER and SPINE do not have client-facing ports #}
{% else %}
  {# This is a LEAF or CLIENT node #}
  {% if DEVICE_HOSTNAME in DEFN_CLIENT_PORTS %}
    {# Device has client-facing port configuration #}
    {% for port_entry in DEFN_CLIENT_PORTS[DEVICE_HOSTNAME] %}
      {# === Port Range Expansion === #}
      {# Check if port spec contains a range (hyphen-separated numbers) #}
      {% if '-' in port_entry.port %}
        {# Port range notation: parse and expand (e.g., Gi0/0/1-5) #}
        {% set parts = port_entry.port.split('-') %}
        {% if parts | length == 2 %}
          {# Locate last slash to separate prefix from start number #}
          {% set prefix_and_start = parts[0] %}
          {% set end_num = parts[1] | int %}
          {% set last_slash = prefix_and_start.rfind('/') %}
          {% set prefix = prefix_and_start[:last_slash + 1] %}
          {% set start_num = prefix_and_start[last_slash + 1:] | int %}
          {# Generate interface configs for each expanded port #}
          {% for i in range(start_num, end_num + 1) %}
            {% set expanded_port = prefix + (i | string) %}
interface {{ expanded_port }}
 description {{ port_entry.description }}
 switchport mode access
 switchport access vlan {{ port_entry.vlan }}
            {% if port_entry.portfast is defined and port_entry.portfast %}
 spanning-tree portfast
            {% endif %}
!
          {% endfor %}
        {% endif %}
      {% else %}
        {# Single port: no range expansion needed #}
interface {{ port_entry.port }}
 description {{ port_entry.description }}
 switchport mode access
 switchport access vlan {{ port_entry.vlan }}
  {% if port_entry.portfast is defined and port_entry.portfast %}
 spanning-tree portfast
  {% endif %}
!
      {% endif %}
    {% endfor %}
  {% endif %}
{% endif %}
