{## CATC: productFamily=Switches and Hubs, softwareType=IOS-XE, productSeries=Cisco Catalyst 9000 Series Virtual Switches ##}
{# ======================================== #}
{# Client Port Utility Macros (Library)     #}
{# ======================================== #}
{# Port range expansion utility: Gi0/0/1-5  #}
{# Note: Currently inlined in FABRIC        #}
{# template; available here for future use  #}

{# Example usage (in a template that includes this file): #}
{# {% set port_list = expand_port_range_inline('Gi0/0/1-5') %} #}
{# {% for port in port_list %} ... {% endfor %} #}

{% macro expand_port_range_inline(port_spec) %}
{# Helper macro: manually expand a port range string into a list #}
{# This is a reference implementation for future template updates #}
{# Input: port_spec string (e.g., 'Gi0/0/1-5', 'Gi0/0/48', 'Gi0/0/1-3,Gi0/0/5') #}
{# Returns: rendered list that can be captured (Jinja2 limitation requires inline logic) #}
[
{%- if '-' in port_spec and ',' not in port_spec %}
  {# Single range: Gi0/0/1-5 #}
  {%- set parts = port_spec.split('-') %}
  {%- if parts | length == 2 %}
    {%- set prefix_and_start = parts[0] %}
    {%- set end_num = parts[1] | int %}
    {%- set last_slash = prefix_and_start.rfind('/') %}
    {%- set prefix = prefix_and_start[:last_slash + 1] %}
    {%- set start_num = prefix_and_start[last_slash + 1:] | int %}
    {%- for i in range(start_num, end_num + 1) %}
      "{{ prefix }}{{ i }}"{{ "," if not loop.last else "" }}
    {%- endfor %}
  {%- endif %}
{%- else %}
  {# Single port or unsupported multi-range: return as-is #}
  "{{ port_spec }}"
{%- endif %}
]
{% endmacro %}

