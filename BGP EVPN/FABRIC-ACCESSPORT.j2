{#- Build Interface Templates -#}

{# Build IOT IBNS Templates #}
{% set vrfArray = [] %}
{% set modeArray = [] %}
{% set intlog = [] %}

{% for device in DEFN_L2OUT %}
  {% if device.node == DEVICE_HOSTNAME %}
    {% for interface, details in device.interfaces.items() %}
      {% if details.vrf in vrfArray %}
      {% else %}
        {% if 'iot' in details.type %}
          {% do vrfArray.append(details['vrf']) %}
          {{ ibns_IOT(details['vrf']) }} 
        {% endif %}
      {% endif %}
    {% endfor %}
    {% for interface, details in device.interfaces.items() %}
      {% if details.mode in modeArray %}
      {% else %}
        {% if 'ibnsconf' in details.mode %}
           {% do modeArray.append(details['mode']) %}
          {{ ibns_accesspoint(vlanArray[1]) }} 
          {{ ibns_workstation(vlanArray[2], vlanArray[3]) }} 
          {{ ibns_baseconfig(vlanArray[1]) }} 
        {% endif %}
        {% if 'autoconf' in details.mode %}
          {% do modeArray.append(details['mode']) %}
            {{ autoconf_accesspoint(vlanArray[1]) }}
            {{ autoconf_workstation(vlanArray[2], vlanArray[3]) }}
            {{ autoconf_baseconfig(vlanArray[1]) }}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}

{#- Interface Configurations -#}
{% set intlog = [] %}

{# Routed Ports and SmartPort Config if used #}
{% for interface in __interface %}
  {% if interface.interfaceType == "Physical" && "GigabitEthernet" in interface.portName.replaceAll("(^[a-zA-Z]+).*","$1") %}
    {% if interface.portName.replaceAll("(^[a-zA-Z]+.).*", "$1") != "GigabitEthernet0" %}
      {% if interface.portName.replaceAll("^[a-zA-Z]+(\\d+)/(\\d+)/(\\d+)", "$2") != 1 %}
        {% if interface.portMode == "routed" %}
          {% if 'autoconf' in modeArray %}
 interface {{ interface.portName }}
  #INTERACTIVE
  access-session inherit disable autoconf<IQ>yes<R>y
  #END_INTERACTIVE 
          {% endif %}
          {% do intlog.append(interface.portName) %}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endif %}
{% endfor %}

{# if 'autoconf' in modeArray #}
