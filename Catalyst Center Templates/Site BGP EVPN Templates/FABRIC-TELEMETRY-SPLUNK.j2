{## CATC: productFamily=Switches and Hubs, softwareType=IOS-XE, productSeries=Cisco Catalyst 9000 Series Virtual Switches ##}
{# FABRIC-TELEMETRY-SPLUNK.j2 - IOS-XE MDT Telemetry subscriptions for Splunk/OpenTelemetry collection #}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-ROLES.j2" %}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-TELEMETRY-SPLUNK.j2" %}
{% set DEVICE_HOSTNAME = __device.hostname | default('', true) %}
{# Telemetry target = union of SPINE, BORDER, and CLIENT roles.                     #}
{# Membership is tested with LITERAL-key lookups (DEFN_NODE_ROLES['ROLE']) - the    #}
{# only reliable pattern in Catalyst Center's included-scope Jinja engine.          #}
{# A previous variable-key iteration (for role in DEFN_TELEMETRY_SPLUNK_ROLES ->    #}
{# DEFN_NODE_ROLES[role]) silently returned empty, so this section never rendered   #}
{# on CLIENT-only nodes (leaves). DEFN_TELEMETRY_SPLUNK_ROLES stays in the DEFN for #}
{# documentation; the roles are enumerated explicitly below to avoid variable keys. #}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['CLIENT'] %}
! =============================================================================
! IOS-XE MDT Telemetry Subscriptions - Campus BGP EVPN VXLAN Fabric
! =============================================================================
! Collector : {{ DEFN_TELEMETRY_SPLUNK_RECEIVER_IP }} (cloud EC2 OTel collector), port {{ DEFN_TELEMETRY_SPLUNK_RECEIVER_PORT }} (yang_grpc)
! Protocol  : gRPC dial-out (receiver ip address format)
! Encoding  : encode-kvgpb
! Source VRF: Mgmt-vrf (all devices)
! IOS-XE    : Validated on 17.18.02 (Cisco CAT9k)
! =============================================================================
!
{% for section in DEFN_TELEMETRY_SPLUNK %}
! -----------------------------------------------------------------------------
! Sub {{ section['subscriptions'][0]['id'] }}{% if section['subscriptions'] | length > 1 %}-{{ section['subscriptions'][-1]['id'] }}{% endif %} - {{ section['section'] }}
! XPath : {{ section['xpath'] }}
! -----------------------------------------------------------------------------
{% for subscription in section['subscriptions'] %}
telemetry ietf subscription {{ subscription['id'] }}
 encoding encode-kvgpb
 filter xpath {{ section['xpath'] }}
 stream yang-push
{% if subscription['policy'] == 'periodic' %}
 update-policy periodic {{ subscription['period'] }}
{% else %}
 update-policy {{ subscription['policy'] }}
{% endif %}
 source-vrf Mgmt-vrf
 receiver ip address {{ DEFN_TELEMETRY_SPLUNK_RECEIVER_IP }} {{ DEFN_TELEMETRY_SPLUNK_RECEIVER_PORT }} protocol grpc-tcp
!
{% endfor %}
{% endfor %}
! =============================================================================
! Verification commands
! =============================================================================
! show telemetry ietf subscription all
! show telemetry ietf subscription 40114 detail
! show telemetry ietf subscription 40119 detail
! show telemetry connection all
! =============================================================================
!
{% endif %}