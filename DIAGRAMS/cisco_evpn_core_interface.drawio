        <mxCell id="legend" value="&lt;table style=&quot;font-size:10px;border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding:2px 8px;&quot;&gt;&lt;hr style=&quot;border:2px solid #C62828;width:30px;display:inline-block;&quot;&gt;&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;&quot;&gt;VRF Red (eBGP, dot1Q 2)&lt;/td&gt;&lt;td style=&quot;padding:2px 8px;&quot;&gt;&lt;hr style=&quot;border:2px dashed #C62828;width:30px;display:inline-block;&quot;&gt;&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;&quot;&gt;VRF Red (cross-path)&lt;/td&gt;&lt;td style=&quot;padding:2px 8px;&quot;&gt;&lt;hr style=&quot;border:2px solid #E65100;width:30px;display:inline-block;&quot;&gt;&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;&quot;&gt;VRF Default (OSPF 1)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=center;verticalAlign=middle;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="350" y="680" width="700" height="30" as="geometry" />
        </mxCell>

        <!-- Physical note -->
        <mxCell id="phys-note" value="&lt;font style=&quot;font-size:10px;color:#555;&quot;&gt;⚠ Each physical link (Gi1/0/5, Gi1/0/6) carries &lt;b&gt;both&lt;/b&gt; VRFs:&lt;br&gt;• Parent interface → VRF Default (OSPF 1 underlay)&lt;br&gt;• dot1Q 2 sub-interface → VRF Red (eBGP tenant routing)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="320" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
