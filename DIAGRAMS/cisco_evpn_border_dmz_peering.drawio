        <mxCell id="evpn-b2" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;eBGP L2VPN EVPN&lt;/b&gt; · Border-02&lt;br&gt;10.101.2.2 (65001) ↔ 198.19.1.200 (65003)&lt;br&gt;multihop 255 · src Lo2&lt;/font&gt;" style="endArrow=classic;startArrow=classic;html=1;rounded=1;dashed=1;dashPattern=8 4;edgeStyle=orthogonalEdgeStyle;strokeColor=#6A1B9A;strokeWidth=2.5;fontColor=#4A148C;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="border-bgp" target="dmz-bgp">
