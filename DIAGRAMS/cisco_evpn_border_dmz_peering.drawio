        <mxCell id="inject" value="&lt;font style=&quot;font-size:9px;&quot;&gt;OSPF 1: redistribute&lt;br&gt;10.100.2.1/32 (DMZ Lo1)&lt;br&gt;via MCLUSTER-LOOPBACKS&lt;/font&gt;" style="endArrow=open;html=1;rounded=1;dashed=1;dashPattern=2 3;edgeStyle=orthogonalEdgeStyle;strokeColor=#616161;strokeWidth=1.5;fontColor=#424242;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.15;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="spine-c" target="dmz-c">
