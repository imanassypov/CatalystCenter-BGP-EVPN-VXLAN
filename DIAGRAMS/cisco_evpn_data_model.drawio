        <!-- ==================== FOOTNOTE ==================== -->
        <mxCell id="foot" value="&lt;div style=&quot;font-size:10px;text-align:left;color:#37474F;line-height:1.5;&quot;&gt;&lt;b&gt;Numbering:&lt;/b&gt; L2VNI = 50000 + VLAN-ID · L3VNI = 50 + VRF-ID.&amp;nbsp;&amp;nbsp;&lt;b&gt;RD&lt;/b&gt; = &amp;lt;node Lo0&amp;gt;:&amp;lt;VRF-ID&amp;gt; (per-device; shown for Leaf-01 Lo0 198.19.1.3) · &lt;b&gt;RT&lt;/b&gt; = &amp;lt;fabric ASN 65001&amp;gt;:&amp;lt;VRF-ID&amp;gt; (fabric-wide).&lt;br&gt;&lt;b&gt;Role scope:&lt;/b&gt; Leaves render L3VNI + L2VNI (full data plane). Spines and Borders render &lt;b&gt;L3VNI only&lt;/b&gt; (VRF route-leak to core / DMZ) — no L2VPN EVPN instances, VLAN configs, or anycast SVIs. VRF red = Spine + Leaf; VRF blue/green = Leaf + Border + DMZ.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fillColor=#FAFAFA;strokeColor=#9E9E9E;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="185" y="946" width="1495" height="72" as="geometry" />
        </mxCell>

