        <!-- GREEN VRF card -->
        <mxCell id="g-card" value="&lt;div style=&quot;font-family:monospace;font-size:10px;text-align:left;color:#FFFFFF;line-height:1.4;&quot;&gt;&lt;b&gt;vrf definition green&lt;/b&gt;&lt;br&gt;&amp;nbsp;rd &lt;b&gt;198.19.1.3:903&lt;/b&gt;&lt;br&gt;&amp;nbsp;route-target export &lt;b&gt;65001:903&lt;/b&gt;&lt;br&gt;&amp;nbsp;route-target import &lt;b&gt;65001:903&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;(+ 65001:903 stitching)&lt;br&gt;&amp;nbsp;mdt default vxlan 239.190.0.3&lt;br&gt;&amp;nbsp;mdt data vxlan 239.190.3.0 0.0.0.255&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fillColor=#66BB6A;strokeColor=#2E7D32;spacingLeft=10;" vertex="1" parent="1">
