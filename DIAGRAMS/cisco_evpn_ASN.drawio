        <mxCell id="legend-text" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;Legend:&lt;/b&gt; &amp;nbsp;—&amp;nbsp; &lt;font color=&quot;#6A1B9A&quot;&gt;&lt;b&gt;Purple dashed&lt;/b&gt;&lt;/font&gt; = eBGP L2VPN EVPN (Borders ↔ DMZ, vrf blue/green extension) &amp;nbsp;|&amp;nbsp; &lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;Green solid&lt;/b&gt;&lt;/font&gt; = eBGP L3OUT (Spines ↔ Core, corporate northbound) &amp;nbsp;|&amp;nbsp; &lt;font color=&quot;#666666&quot;&gt;Gray&lt;/font&gt; = DMZ ↔ Core physical uplink eBGP&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
