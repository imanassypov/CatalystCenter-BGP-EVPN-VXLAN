        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;BGP ASN Domains &amp;amp; Peering Relationships&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666;&quot;&gt;Campus fabric (65001) · Enterprise IP Core (65002) · Multi-cluster DMZ (65003 Location A + 65004 Location B)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontColor=#333333;" vertex="1" parent="1">
