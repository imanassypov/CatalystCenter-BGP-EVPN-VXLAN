{
  "servers": {
    "evpn-ssh": {
      "type": "stdio",
      "command": "/path/to/python",
      "args": [
        "/path/to/CICD Pipeline/utils/mcp-ssh-server/server.py"
      ],
      "env": {
        "MCP_SSH_DEFAULT_TIMEOUT": "60"
      },
      "envFile": "/path/to/CICD Pipeline/.env"
    }
  }
}
